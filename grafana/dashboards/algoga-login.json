{
  "title": "Algoga Login Bottleneck Analysis",
  "uid": "algoga-login-bottleneck",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "Asia/Seoul",
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "🔥 핵심 증명 지표: DB 커넥션 풀 vs CPU",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "HikariCP DB 커넥션 상태 (병목의 원인)",
      "type": "timeseries",
      "description": "최적화 전에는 Active가 Max(10)를 찍고 평행선을 달립니다. 최적화 후에는 커넥션 반납이 빨라져 Active가 낮게 유지됩니다.",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "hikaricp_connections_active",
          "legendFormat": "사용 중인 커넥션 (Active)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "hikaricp_connections_pending",
          "legendFormat": "대기 중인 요청 (Pending)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "hikaricp_connections_max",
          "legendFormat": "최대 커넥션 (Max)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "min": 0 } }
    },
    {
      "id": 2,
      "title": "서버 CPU 사용량 (Bcrypt 부하)",
      "type": "timeseries",
      "description": "DB 커넥션을 쥐고 있든 아니든 Bcrypt 연산 자체는 CPU를 씁니다. 트랜잭션 분리 후 트래픽을 더 많이 소화하면서 CPU 사용량이 더 높아질 수 있습니다.",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "process_cpu_usage * 100",
          "legendFormat": "Spring Boot 프로세스 CPU (%)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 200,
      "type": "row",
      "title": "⚡ 사용자 체감 성능 (응답 지연 및 에러)",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 3,
      "title": "로그인 API 처리 결과 (성공 vs 에러)",
      "type": "timeseries",
      "description": "커넥션 풀이 마르면 500 에러(Timeout)가 치솟습니다. 최적화 후에는 500 에러가 사라져야 합니다.",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/api/v1/auth/login\", status=\"200\"}[1m]))",
          "legendFormat": "로그인 성공 (200 OK)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/api/v1/auth/login\", status=\"500\"}[1m]))",
          "legendFormat": "DB 타임아웃 에러 (500 ERROR)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 4,
      "title": "로그인 지연 시간 (p95)",
      "type": "timeseries",
      "description": "최적화 전에는 커넥션 대기 시간까지 더해져 지연 시간이 깁니다. 최적화 후에는 순수 Bcrypt 연산 시간(약 0.3~0.5초)에 가깝게 줄어듭니다.",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{uri=\"/api/v1/auth/login\"}[1m]))",
          "legendFormat": "p95 응답 시간"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}