{
    "title":  "Algoga LMS Learning Progress",
    "uid":  "algoga-lms-learning-progress",
    "schemaVersion":  38,
    "version":  2,
    "refresh":  "10s",
    "time":  {
                 "from":  "now-1h",
                 "to":  "now"
             },
    "timezone":  "Asia/Seoul",
    "panels":  [
                   {
                       "id":  100,
                       "type":  "row",
                       "title":  "Learning Progress API Baseline",
                       "gridPos":  {
                                       "x":  0,
                                       "y":  0,
                                       "w":  24,
                                       "h":  1
                                   },
                       "collapsed":  false,
                       "panels":  [

                                  ]
                   },
                   {
                       "id":  1,
                       "title":  "Progress Update TPS",
                       "type":  "timeseries",
                       "description":  "Requests per second for POST /api/v1/courses/{courseId}/chapters/{chapterId}/progress during k6 load test.",
                       "gridPos":  {
                                       "x":  0,
                                       "y":  1,
                                       "w":  8,
                                       "h":  8
                                   },
                       "targets":  [
                                       {
                                           "datasource":  {
                                                              "type":  "prometheus",
                                                              "uid":  "prometheus_ds"
                                                          },
                                           "expr":  "sum(rate(http_server_requests_seconds_count{uri=\"/api/v1/courses/{courseId}/chapters/{chapterId}/progress\", status=\"200\"}[1m]))",
                                           "legendFormat":  "success TPS"
                                       },
                                       {
                                           "datasource":  {
                                                              "type":  "prometheus",
                                                              "uid":  "prometheus_ds"
                                                          },
                                           "expr":  "sum(rate(http_server_requests_seconds_count{uri=\"/api/v1/courses/{courseId}/chapters/{chapterId}/progress\", status=~\"4..|5..\"}[1m]))",
                                           "legendFormat":  "error TPS"
                                       }
                                   ],
                       "fieldConfig":  {
                                           "defaults":  {
                                                            "unit":  "reqps"
                                                        }
                                       }
                   },
                   {
                       "id":  2,
                       "title":  "Progress Update Latency p50 / p95 / p99",
                       "type":  "timeseries",
                       "description":  "Main before/after comparison panel. Redis write-behind should reduce DB write pressure and improve or stabilize p95 latency.",
                       "gridPos":  {
                                       "x":  8,
                                       "y":  1,
                                       "w":  8,
                                       "h":  8
                                   },
                       "targets":  [
                                       {
                                           "datasource":  {
                                                              "type":  "prometheus",
                                                              "uid":  "prometheus_ds"
                                                          },
                                           "expr":  "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{uri=\"/api/v1/courses/{courseId}/chapters/{chapterId}/progress\"}[$__rate_interval]))",
                                           "legendFormat":  "p99"
                                       },
                                       {
                                           "datasource":  {
                                                              "type":  "prometheus",
                                                              "uid":  "prometheus_ds"
                                                          },
                                           "expr":  "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{uri=\"/api/v1/courses/{courseId}/chapters/{chapterId}/progress\"}[$__rate_interval]))",
                                           "legendFormat":  "p95"
                                       },
                                       {
                                           "datasource":  {
                                                              "type":  "prometheus",
                                                              "uid":  "prometheus_ds"
                                                          },
                                           "expr":  "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{uri=\"/api/v1/courses/{courseId}/chapters/{chapterId}/progress\"}[$__rate_interval]))",
                                           "legendFormat":  "p50"
                                       }
                                   ],
                       "fieldConfig":  {
                                           "defaults":  {
                                                            "unit":  "s"
                                                        }
                                       }
                   },
                   {
                       "id":  3,
                       "title":  "Progress Update Error Rate",
                       "type":  "timeseries",
                       "description":  "4xx and 5xx ratio for the progress update API. A valid baseline should stay near 0% after enrollment and chapter order are set correctly.",
                       "gridPos":  {
                                       "x":  16,
                                       "y":  1,
                                       "w":  8,
                                       "h":  8
                                   },
                       "targets":  [
                                       {
                                           "datasource":  {
                                                              "type":  "prometheus",
                                                              "uid":  "prometheus_ds"
                                                          },
                                           "expr":  "sum(rate(http_server_requests_seconds_count{uri=\"/api/v1/courses/{courseId}/chapters/{chapterId}/progress\", status=~\"4..|5..\"}[1m])) / clamp_min(sum(rate(http_server_requests_seconds_count{uri=\"/api/v1/courses/{courseId}/chapters/{chapterId}/progress\"}[1m])), 0.001) * 100",
                                           "legendFormat":  "error rate"
                                       }
                                   ],
                       "fieldConfig":  {
                                           "defaults":  {
                                                            "unit":  "percent",
                                                            "min":  0,
                                                            "thresholds":  {
                                                                               "steps":  [
                                                                                             {
                                                                                                 "color":  "green",
                                                                                                 "value":  null
                                                                                             },
                                                                                             {
                                                                                                 "color":  "yellow",
                                                                                                 "value":  1
                                                                                             },
                                                                                             {
                                                                                                 "color":  "red",
                                                                                                 "value":  5
                                                                                             }
                                                                                         ]
                                                                           }
                                                        }
                                       }
                   },
                   {
                       "id":  101,
                       "type":  "row",
                       "title":  "DB Pressure",
                       "gridPos":  {
                                       "x":  0,
                                       "y":  9,
                                       "w":  24,
                                       "h":  1
                                   },
                       "collapsed":  false,
                       "panels":  [

                                  ]
                   },
                   {
                       "id":  4,
                       "title":  "HikariCP Connections",
                       "type":  "timeseries",
                       "description":  "Use this for before/after evidence. Before write-behind, frequent progress saves can increase active/pending DB connections.",
                       "gridPos":  {
                                       "x":  0,
                                       "y":  10,
                                       "w":  12,
                                       "h":  8
                                   },
                       "targets":  [
                                       {
                                           "datasource":  {
                                                              "type":  "prometheus",
                                                              "uid":  "prometheus_ds"
                                                          },
                                           "expr":  "hikaricp_connections_active",
                                           "legendFormat":  "Active"
                                       },
                                       {
                                           "datasource":  {
                                                              "type":  "prometheus",
                                                              "uid":  "prometheus_ds"
                                                          },
                                           "expr":  "hikaricp_connections_idle",
                                           "legendFormat":  "Idle"
                                       },
                                       {
                                           "datasource":  {
                                                              "type":  "prometheus",
                                                              "uid":  "prometheus_ds"
                                                          },
                                           "expr":  "hikaricp_connections_pending",
                                           "legendFormat":  "Pending"
                                       }
                                   ]
                   },
                   {
                       "id":  5,
                       "title":  "HikariCP Acquire Avg",
                       "type":  "timeseries",
                       "description":  "Average connection acquire latency. The project exposes Hikari acquire time as a summary, not histogram buckets.",
                       "gridPos":  {
                                       "x":  12,
                                       "y":  10,
                                       "w":  12,
                                       "h":  8
                                   },
                       "targets":  [
                                       {
                                           "datasource":  {
                                                              "type":  "prometheus",
                                                              "uid":  "prometheus_ds"
                                                          },
                                           "expr":  "sum(rate(hikaricp_connections_acquire_seconds_sum[$__rate_interval])) / clamp_min(sum(rate(hikaricp_connections_acquire_seconds_count[$__rate_interval])), 0.001)",
                                           "legendFormat":  "acquire avg"
                                       }
                                   ],
                       "fieldConfig":  {
                                           "defaults":  {
                                                            "unit":  "s"
                                                        }
                                       }
                   },
                   {
